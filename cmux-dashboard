#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="/tmp/cmux-dashboard.pid"
LOG_FILE="${DASHBOARD_LOG_FILE:-/tmp/cmux-dashboard.log}"

usage() {
  cat <<'EOF'
Usage:
  ./cmux-dashboard start [port]
  ./cmux-dashboard stop
  ./cmux-dashboard restart [port]

Commands:
  start   Start dashboard.py (default port: 9091)
  stop    Stop the running dashboard process
  restart Restart dashboard.py

Examples:
  ./cmux-dashboard start 8080
  ./cmux-dashboard stop
  ./cmux-dashboard restart
EOF
}

is_running() {
  local running_pids
  running_pids="$(get_running_pids)"
  [[ -n "$running_pids" ]]
}

get_running_pids() {
  local -a pids=()
  local pid
  local cmd

  if [[ -f "$PID_FILE" ]]; then
    pid="$(cat "$PID_FILE")"
    if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
      pids+=("$pid")
    else
      rm -f "$PID_FILE"
    fi
  fi

  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    if ! kill -0 "$pid" 2>/dev/null; then
      continue
    fi
    cmd="$(ps -p "$pid" -o args= 2>/dev/null || true)"
    [[ -z "$cmd" ]] && continue
    if [[ "$cmd" != *"dashboard.py"* ]]; then
      continue
    fi
    for existing in "${pids[@]}"; do
      if [[ "$existing" == "$pid" ]]; then
        continue 2
      fi
    done
    pids+=("$pid")
  done < <(pgrep -f "dashboard.py" 2>/dev/null || true)

  if ((${#pids[@]})); then
    printf '%s\n' "${pids[@]}"
  fi
}

start_dashboard() {
  local port="${1:-}"
  local running_pids
  running_pids="$(get_running_pids)"

  if [[ -n "$running_pids" ]]; then
    echo "dashboard is already running (pid $(echo "$running_pids" | head -n 1))"
    return 0
  fi

  if [[ -n "$port" ]]; then
    nohup python3 "$ROOT_DIR/dashboard.py" "$port" >> "$LOG_FILE" 2>&1 &
  else
    nohup python3 "$ROOT_DIR/dashboard.py" >> "$LOG_FILE" 2>&1 &
  fi
  echo $! > "$PID_FILE"
  echo "started dashboard.py (pid $!); logs: $LOG_FILE"
}

stop_dashboard() {
  local running_pids
  running_pids="$(get_running_pids)"

  if [[ -z "$running_pids" ]]; then
    echo "dashboard is not running"
    return 0
  fi

  local pid
  local failed=0
  while IFS= read -r pid; do
    if kill "$pid" 2>/dev/null; then
      echo "stopped dashboard (pid $pid)"
    else
      echo "failed to stop dashboard (pid $pid)"
      failed=1
    fi
  done <<< "$running_pids"

  rm -f "$PID_FILE"
  return $failed
}

restart_dashboard() {
  stop_dashboard || true
  start_dashboard "$@"
}

case "${1:-}" in
  start)
    start_dashboard "${2:-}"
    ;;
  stop)
    stop_dashboard
    ;;
  restart)
    restart_dashboard "${2:-}"
    ;;
  *)
    usage
    exit 1
    ;;
esac
